rnd.zenzerobiogas.com {
    # MQTT WebSocket proxy → broker port 8083 (plain WS, no backend needed)
    handle /ws {
        rewrite * /mqtt
        reverse_proxy mqtt.zenzerobiogas.com:8083 {
            transport http {
                versions 1.1
            }
            header_up Host mqtt.zenzerobiogas.com
        }
    }

    # SPA frontend
    handle {
        root * /home/teddy/rnd-zenzero-public
        file_server
        try_files {path} /index.html
    }
}
