rnd.zenzerobiogas.com {
    # MQTT WebSocket proxy → the production EMQX instance used by zenmac-backend
    handle /ws {
        rewrite * /mqtt
        reverse_proxy 127.0.0.1:8085 {
            transport http {
                versions 1.1
            }
            header_up Host rnd.zenzerobiogas.com
        }
    }

    # SPA frontend
    handle {
        root * /home/teddy/rnd-zenzero-public
        file_server
        try_files {path} /index.html
    }
}
