# Copy ไฟล์นี้เป็น .env แล้วแก้ค่าตาม environment
# cp .env.example .env

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000

# ── MQTT Broker (TCP) ─────────────────────────────────────────────────────────
MQTT_URL=mqtt://mqtt.zenzerobiogas.com:1884

# ── MQTT Topics ───────────────────────────────────────────────────────────────
TOPIC_STATUS=Demo/zenmac/QQ
TOPIC_CMD=Demo/zenmac/cmd
TOPIC_AUTH=Demo/zenmac/authority
