# ── MQTT Broker ──────────────────────────────────────────────────────────────
VITE_MQTT_HOST=mqtt.zenzerobiogas.com
VITE_MQTT_PORT=1884

# ── MQTT WebSocket Gateway ────────────────────────────────────────────────────
# Port ของ broker ที่รับ WebSocket (ไม่ต้องตั้ง VITE_GATEWAY_URL ถ้าใช้ auto-detect)
VITE_MQTT_WS_PORT=9001

# ── MQTT Topics ───────────────────────────────────────────────────────────────
VITE_TOPIC_STATUS=Demo/zenmac/QQ
VITE_TOPIC_CMD=Demo/zenmac/QQ
VITE_TOPIC_AUTH=Demo/zenmac/authority
