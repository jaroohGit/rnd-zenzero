# Copy ไฟล์นี้เป็น .env.local แล้วแก้ค่าตาม environment
# cp .env.example .env.local

# ── MQTT Broker ──────────────────────────────────────────────────────────────
VITE_MQTT_HOST=mqtt.zenzerobiogas.com
VITE_MQTT_PORT=1884
VITE_MQTT_WS_URL=wss://rnd.zenzerobiogas.com/ws

# ── MQTT Topics ───────────────────────────────────────────────────────────────
VITE_TOPIC_STATUS=Demo/zenmac/QQ
VITE_TOPIC_CMD=Demo/zenmac/cmd
VITE_TOPIC_AUTH=Demo/zenmac/authority

# ── MQTT WebSocket URL (optional) ─────────────────────────────────────────────
# ตั้งเมื่อต้องการ override auto-detect
# VITE_MQTT_WS_URL=wss://mqtt.zenzerobiogas.com/mqtt
